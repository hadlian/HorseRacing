# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Virtual environment
venv/
.venv/
env/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Generated outputs (don't commit — re-run to produce)
results/*.db
results/*.xlsx
comparemodels/*.db
scout/*.json
scout/*.txt

# Analysis TXT outputs — committed at repo root
Claude/*_R5_analysis.txt

# DRF data files and input directories (binary, large, track-specific)
files 2/
files/

# Binary / document formats — not tracked
*.xlsm
*.xlsx
*.pdf
*.docx
*.rtf
*.zip
~$*

# CSV — ignore all except the results template
*.csv
!results/results_template.csv
*.html
!webapp/templates/*.html
*.textClipping

# Results HTML companion folders and legacy results
Results/2025/
Results/**/*_files/

# Legacy / auxiliary directories — not part of R5 codebase
Bris Schema XLSX/
database/
sqlfiles/
PythonCode/

# Prompts — track .txt only, ignore binaries
Prompts/*.zip
Prompts/*.rtf
Prompts/*.docx

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Claude memory (local only)
.claude/

