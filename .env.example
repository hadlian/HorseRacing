# Copy to .env to override data locations (defaults target ~/Documents/RacingData).
# R5_DATA_DIR    — read-only DRF input root (contains "files 2/")
# R5_RESULTS_DIR — single-writer output root (r5_results.db + artifacts)
R5_DATA_DIR=/Users/harryadalian/Documents/RacingData
R5_RESULTS_DIR=/Users/harryadalian/Documents/RacingData/Results
